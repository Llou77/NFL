# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.env
.venv/
venv/

# Data files (large — not committed to repo)
data/raw/*.parquet
data/processed/*.parquet
data/pipeline.log

# Model artifacts (large — not committed unless small)
model/saved/*.pt
model/saved/*.pkl
model/saved/*.json
model/saved/*.txt
# But DO commit version.txt and optimal_weights.json
!model/saved/version.txt
!model/saved/optimal_weights.json

# Predictions ARE committed (they're the site's data source)
!data/predictions/predictions_latest.json
!data/predictions/performance.json
!data/predictions/backtest_results.json

# IDEs
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb
